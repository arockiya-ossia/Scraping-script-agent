# LLM (freellmapi — https://github.com/tashfeenahmed/freellmapi)
FREELLMAPI_BASE_URL=
FREELLMAPI_API_KEY=
FREELLMAPI_MODEL=auto

# Search
SERPER_API_KEY=
SERPAPI_API_KEY=
FIRECRAWL_API_KEY=

# Agent behavior
MAX_REPAIR_ATTEMPTS=5
MAX_TOTAL_ATTEMPTS=8
SANDBOX_TIMEOUT_SECONDS=120

# Sandbox execution (Docker) — see docker-compose.yml + agent/sandbox/egress_proxy
SANDBOX_IMAGE=job-scraper-sandbox
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_CPU_LIMIT=1
SANDBOX_NETWORK=sandbox_net
EGRESS_PROXY_HOST=egress-proxy:3128

# Paths
OUTPUT_DIR=generated_scripts
TRACE_DIR=traces
ARTIFACTS_DIR=artifacts
